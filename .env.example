# 在智谱开放平台创建 API Key：https://open.bigmodel.cn/
# 复制本文件为 .env，把下面占位符换成控制台复制的密钥（整串应为 ASCII）

ZHIPU_API_KEY=paste_your_ascii_api_key_here

# 需支持「工具调用」的模型；若报错可改为 glm-4.7 等
GLM_MODEL=glm-4-flash

# 可选：单轮内模型↔工具最多循环次数
# MAX_TOOL_ROUNDS=8

# 可选：messages 最大条数（含 system），超出则从旧消息开始删
# MAX_CONTEXT_MESSAGES=24

# 可选：知识库目录（相对 demo_agent 或绝对路径）
# KNOWLEDGE_DIR=knowledge

# RAG：返回片段数、切块大小与重叠
# RAG_TOP_K=3
# RAG_CHUNK_SIZE=400
# RAG_CHUNK_OVERLAP=80

# 观测：JSONL 日志目录（相对 demo_agent）。设为 0 / false / off 可关闭写文件
TRACE_JSONL_DIR=logs
